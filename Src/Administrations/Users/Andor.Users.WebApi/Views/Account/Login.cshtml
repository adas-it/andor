@model Andor.Users.WebApi.Controllers.LoginViewModel
@{
    ViewData["Title"] = "Sign In";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Sign In</h2>

@if (!ViewData.ModelState.IsValid)
{
    <div class="validation-summary-errors">
        @Html.ValidationSummary(excludePropertyErrors: true)
    </div>
}

<form method="post" action="/account/login">
    @Html.AntiForgeryToken()
    <input type="hidden" name="ReturnUrl" value="@Model.ReturnUrl" />

    <label for="UserName">Username</label>
    <input type="text" id="UserName" name="UserName" value="@Model.UserName" autocomplete="username" required />
    @Html.ValidationMessage("UserName", new { @class = "field-validation-error" })

    <label for="Password">Password</label>
    <input type="password" id="Password" name="Password" autocomplete="current-password" required />
    @Html.ValidationMessage("Password", new { @class = "field-validation-error" })

    <button type="submit">Sign In</button>
</form>
